{
  "name": "playwright_framework",
  "version": "1.0.0",
  "description": "Opinionated Playwright E2E framework with unified runner, context-aware recording, and Allure reporting.",
  "main": "index.js",
  "scripts": {
    "codegen:demo": "node ./scripts/run-codegen.cjs --name demo --url https://playwright.dev/",
    "test:demo": "node ./scripts/run-e2e.cjs --target tests/demo/google-demo.spec.ts --headed",
    "codegen:interview-login": "node ./scripts/run-codegen.cjs --name interview-login --url https://localhost:5173/#/pages/login/index",
    "test:interview-login": "node ./scripts/run-e2e.cjs --target tests/interview_agent/login/login.spec.ts --headed"
  },
  "keywords": [
    "playwright",
    "e2e",
    "automation",
    "testing",
    "allure",
    "codegen",
    "web-testing",
    "test-framework"
  ],
  "author": "MenXiaoHuan",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "~1.61.1",
    "@types/node": "^25.9.1",
    "allure": "^3.9.0",
    "allure-playwright": "^3.9.0",
    "tsx": "^4.22.4"
  }
}
